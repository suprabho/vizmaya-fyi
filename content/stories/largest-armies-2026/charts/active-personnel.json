{
  "steps": [
    {
      "title": "Active-duty military personnel, 2026",
      "option": {
        "tooltip": {
          "trigger": "axis",
          "axisPointer": { "type": "shadow" },
          "formatter": "{b}: {c}M active"
        },
        "grid": {
          "left": "3%",
          "right": "8%",
          "bottom": "3%",
          "top": "8%",
          "containLabel": true
        },
        "xAxis": {
          "type": "value",
          "axisLine": { "show": false },
          "axisTick": { "show": false },
          "axisLabel": {
            "formatter": "{value}M",
            "color": "$muted"
          },
          "splitLine": {
            "lineStyle": { "color": "$line" }
          }
        },
        "yAxis": {
          "type": "category",
          "data": [
            "Bangladesh",
            "South Korea",
            "Vietnam",
            "Pakistan",
            "Ukraine",
            "Russia",
            "U.S.",
            "North Korea",
            "India",
            "China"
          ],
          "axisLine": { "show": false },
          "axisTick": { "show": false },
          "axisLabel": {
            "color": "$text",
            "fontSize": 12
          },
          "splitLine": { "show": false }
        },
        "series": [
          {
            "name": "Active personnel",
            "type": "bar",
            "barWidth": 22,
            "label": {
              "show": true,
              "position": "right",
              "color": "$text",
              "formatter": "{c}M",
              "fontFamily": "JetBrains Mono",
              "fontSize": 12
            },
            "data": [
              { "value": 0.2, "itemStyle": { "color": "$muted" } },
              { "value": 0.5, "itemStyle": { "color": "$muted" } },
              { "value": 0.5, "itemStyle": { "color": "$muted" } },
              { "value": 0.7, "itemStyle": { "color": "$muted" } },
              { "value": 0.9, "itemStyle": { "color": "$positive" } },
              { "value": 1.3, "itemStyle": { "color": "$amber" } },
              { "value": 1.3, "itemStyle": { "color": "$amber" } },
              { "value": 1.3, "itemStyle": { "color": "$amber" } },
              { "value": 1.4, "itemStyle": { "color": "$red" } },
              { "value": 2.0, "itemStyle": { "color": "$red" } }
            ]
          }
        ]
      }
    }
  ]
}
