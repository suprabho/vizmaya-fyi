{
  "steps": [
    {
      "title": "Korean peninsula — personnel by country, 2026",
      "option": {
        "tooltip": {
          "trigger": "axis",
          "axisPointer": { "type": "shadow" },
          "formatter": "{b}<br/>{a0}: {c0}M<br/>{a1}: {c1}M"
        },
        "legend": {
          "bottom": 0,
          "textStyle": { "color": "$muted", "fontSize": 11 },
          "data": ["Active", "Reserves + Paramilitary"]
        },
        "grid": {
          "left": "3%",
          "right": "8%",
          "bottom": "14%",
          "top": "10%",
          "containLabel": true
        },
        "xAxis": {
          "type": "value",
          "axisLine": { "show": false },
          "axisTick": { "show": false },
          "axisLabel": {
            "formatter": "{value}M",
            "color": "$muted"
          },
          "splitLine": {
            "lineStyle": { "color": "$line" }
          }
        },
        "yAxis": {
          "type": "category",
          "data": ["North Korea", "South Korea"],
          "axisLine": { "show": false },
          "axisTick": { "show": false },
          "axisLabel": {
            "color": "$text",
            "fontSize": 13
          },
          "splitLine": { "show": false }
        },
        "series": [
          {
            "name": "Active",
            "type": "bar",
            "stack": "total",
            "barWidth": 32,
            "itemStyle": { "color": "$red" },
            "label": {
              "show": true,
              "position": "insideLeft",
              "color": "$text",
              "formatter": "{c}M active",
              "fontFamily": "JetBrains Mono",
              "fontSize": 11
            },
            "data": [1.3, 0.5]
          },
          {
            "name": "Reserves + Paramilitary",
            "type": "bar",
            "stack": "total",
            "barWidth": 32,
            "itemStyle": { "color": "$positive" },
            "label": {
              "show": true,
              "position": "right",
              "color": "$text",
              "formatter": "total {@[0]}M",
              "fontFamily": "JetBrains Mono",
              "fontSize": 11
            },
            "data": [0.7, 3.2]
          }
        ]
      }
    }
  ]
}
