{
  "steps": [
    {
      "title": "Biggest rank gains, 2025 → 2026",
      "option": {
        "tooltip": {
          "trigger": "axis",
          "axisPointer": { "type": "shadow" },
          "formatter": "{b}: +{c} ranks"
        },
        "grid": {
          "left": "3%",
          "right": "10%",
          "bottom": "3%",
          "top": "8%",
