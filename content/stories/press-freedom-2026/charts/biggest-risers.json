            "data": [
              { "value": 14, "itemStyle": { "color": "$accent2" } },
              { "value": 16, "itemStyle": { "color": "$accent2" } },
              { "value": 17, "itemStyle": { "color": "$accent" } },
              { "value": 18, "itemStyle": { "color": "$accent" } },
              { "value": 18, "itemStyle": { "color": "$accent" } },
              { "value": 36, "itemStyle": { "color": "$accent" } }
