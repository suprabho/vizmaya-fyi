{
  "steps": [
    {
      "title": "Foreign Ownership of U.S. Debt — Top Creditor Nations",
      "option": {
        "tooltip": {
          "trigger": "axis",
          "axisPointer": { "type": "shadow" },
          "formatter": "{b}: ${c}T"
        },
        "grid": {
          "left": "3%",
          "right": "10%",
          "bottom": "3%",
          "top": "8%",
          "containLabel": true
        },
        "xAxis": {
          "type": "value",
          "axisLine": { "show": false },
          "axisTick": { "show": false },
          "axisLabel": {
            "formatter": "${value}T",
            "color": "$muted"
          },
          "splitLine": {
            "lineStyle": { "color": "$line" }
          }
        },
        "yAxis": {
          "type": "category",
          "data": [
            "Other Nations",
            "China",
            "United Kingdom",
            "Japan"
          ],
          "axisLine": { "show": false },
          "axisTick": { "show": false },
          "axisLabel": {
            "color": "$text",
            "fontSize": 12
          },
          "splitLine": { "show": false }
        },
        "series": [
          {
            "name": "Treasury Holdings",
            "type": "bar",
            "barWidth": 24,
            "label": {
              "show": true,
              "position": "right",
              "color": "$text",
              "formatter": "${c}T",
              "fontFamily": "JetBrains Mono",
              "fontSize": 11
            },
            "data": [
              { "value": 6.5, "itemStyle": { "color": "$muted" } },
              { "value": 0.7, "itemStyle": { "color": "$red" } },
              { "value": 0.9, "itemStyle": { "color": "#d46a6a" } },
              { "value": 1.2, "itemStyle": { "color": "$accent" } }
            ]
          }
        ]
      }
    }
  ]
}
